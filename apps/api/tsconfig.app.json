{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "declaration": true,
    "types": ["node", "multer"]
  },
  "include": [
    "src/**/*.ts",
    "../../libs/**/src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts",
    "src/**/*.test.ts",
    "jest.config.ts",
    "../../libs/**/*.spec.ts",
    "../../libs/**/*.test.ts",
    "../../libs/**/ui/**/*.ts"
  ]
}
