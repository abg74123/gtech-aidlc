# ===========================================
# Autoflow — Local Development Environment
# ===========================================
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env

# --- PostgreSQL ---
POSTGRES_DB=autoflow
POSTGRES_USER=autoflow
POSTGRES_PASSWORD=autoflow_secret
POSTGRES_PORT=5432

# --- Prisma DATABASE_URL ---
# Format: postgresql://user:password@host:port/dbname?schema=public
DATABASE_URL=postgresql://autoflow:autoflow_secret@localhost:5432/autoflow?schema=public

# --- JWT ---
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- API ---
API_PORT=3000
API_PREFIX=api/v1
