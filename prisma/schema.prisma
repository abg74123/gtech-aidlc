// Autoflow — Prisma Schema
// Multi-schema: master_data, transactions, warehouse, reports

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["master_data", "transactions", "warehouse", "reports"]
}

// ─── Enums (master_data) ─────────────────────────────────────────────────────

enum Role {
  CASHIER
  STORE
  SUPERVISOR
  MANAGER
  CFO
  ADMIN

  @@schema("master_data")
}

// ─── Enums (transactions) ────────────────────────────────────────────────────

enum JOStatus {
  OPEN
  IN_PROGRESS
  DONE

  @@schema("transactions")
}

enum ApArStatus {
  OPEN
  PARTIAL
  CLOSED

  @@schema("transactions")
}

enum ClearingStatus {
  OPEN
  CLOSED

  @@schema("transactions")
}

// ─── Models (master_data) ────────────────────────────────────────────────────

// ── User & Auth ──────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  email        String?  @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  roles        Role[]   @default([])
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]
  userRoles     UserRole[]
  periodsOpened Period[]       @relation("PeriodOpenedBy")
  periodsClosed Period[]       @relation("PeriodClosedBy")

  @@map("users")
  @@schema("master_data")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  token     String    @unique
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt], name: "idx_refresh_token_user_active")
  @@map("refresh_tokens")
  @@schema("master_data")
}

// ── Role Table (normalized role metadata) ────────────────────────────────────

model RoleRecord {
  id          String  @id @default(uuid()) @db.Uuid
  name        String  @unique @db.VarChar(20)
  description String? @db.VarChar(200)

  userRoles UserRole[]

  @@map("role")
  @@schema("master_data")
}

// ── User-Role Bridge ─────────────────────────────────────────────────────────

model UserRole {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role RoleRecord @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_role")
  @@schema("master_data")
}

// ── Period ────────────────────────────────────────────────────────────────────

model Period {
  id       String    @id @default(uuid()) @db.Uuid
  period   String    @unique @db.VarChar(7)
  status   String    @default("OPEN") @db.VarChar(10)
  openedBy String    @map("opened_by") @db.Uuid
  openedAt DateTime  @map("opened_at")
  closedBy String?   @map("closed_by") @db.Uuid
  closedAt DateTime? @map("closed_at")

  openedByUser User  @relation("PeriodOpenedBy", fields: [openedBy], references: [id])
  closedByUser User? @relation("PeriodClosedBy", fields: [closedBy], references: [id])

  @@map("period")
  @@schema("master_data")
}

// ── Item ──────────────────────────────────────────────────────────────────────

model Item {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(200)
  unit      String   @db.VarChar(20)
  category  String?  @db.VarChar(50)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  txLogs        TxLog[]
  stockBalances StockBalance[]

  @@map("item")
  @@schema("master_data")
}

// ── Warehouse ─────────────────────────────────────────────────────────────────

model Warehouse {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(200)
  location  String?  @db.VarChar(300)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  txLogs        TxLog[]
  stockBalances StockBalance[]

  @@map("warehouse")
  @@schema("master_data")
}

// ── Vendor ────────────────────────────────────────────────────────────────────

model Vendor {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(200)
  taxId     String?  @map("tax_id") @db.VarChar(20)
  address   String?  @db.Text
  phone     String?  @db.VarChar(20)
  email     String?  @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  txLogs TxLog[] @relation("TxLogVendor")

  @@map("vendor")
  @@schema("master_data")
}

// ── Customer ──────────────────────────────────────────────────────────────────

model Customer {
  id        String   @id @default(uuid()) @db.Uuid
  code      String   @unique @db.VarChar(20)
  name      String   @db.VarChar(200)
  taxId     String?  @map("tax_id") @db.VarChar(20)
  address   String?  @db.Text
  phone     String?  @db.VarChar(20)
  email     String?  @db.VarChar(100)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  txLogs TxLog[] @relation("TxLogCustomer")

  @@map("customer")
  @@schema("master_data")
}

// ─── Transactions Schema ─────────────────────────────────────────────────────

// ── Enums (transactions schema) ──────────────────────────────────────────────

enum TxType {
  // Sales
  JOB_ORDER
  TEMP_DO
  INVOICE_FROM_DO
  SALE_INVOICE
  CN_SALES_RETURN
  CN_SALES_PRICE
  AR_RECEIVE
  AR_CN_DEBT
  AR_DN
  // Purchasing
  GR_RECEIVE
  GR_RETURN
  GR_REPLACEMENT
  CN_RETURN
  CN_PRICE_ADJ
  AP_CN_DEBT
  AP_PAYMENT
  AP_DN
  AP_DN_REF
  // Warehouse / Adjustments
  ADJ_COUNT_UP
  ADJ_COUNT_DOWN
  ADJ_WRITEDOWN
  ADJ_WRITEOFF
  ADJ_TRANSFER
  ADJ_RECLASS
  ADJ_COST
  SUPPLY_ISSUE
  // Other
  WHT_RECORD
  CHEQUE_RECEIVE
  EXPENSE_RECORD
  VOID

  @@schema("transactions")
}

enum TxStatus {
  DRAFT
  POSTED
  VOIDED

  @@schema("transactions")
}

enum VatType {
  INPUT
  OUTPUT
  NONE

  @@schema("transactions")
}

enum ApArStatus {
  OPEN
  PARTIAL
  CLOSED

  @@schema("transactions")
}

// ── TX Log ───────────────────────────────────────────────────────────────────

model TxLog {
  id           String      @id @default(uuid()) @db.Uuid
  txType       TxType      @map("tx_type")
  txStatus     TxStatus    @default(DRAFT) @map("tx_status")
  txDate       DateTime    @map("tx_date") @db.Timestamptz
  period       String      @db.VarChar(7)
  itemId       String?     @map("item_id") @db.Uuid
  warehouseId  String?     @map("warehouse_id") @db.Uuid
  qty          Decimal?    @db.Decimal(12, 4)
  unitCost     Decimal?    @map("unit_cost") @db.Decimal(12, 2)
  totalCost    Decimal?    @map("total_cost") @db.Decimal(14, 2)
  maBefore     Decimal?    @map("ma_before") @db.Decimal(12, 2)
  maAfter      Decimal?    @map("ma_after") @db.Decimal(12, 2)
  stockBefore  Decimal?    @map("stock_before") @db.Decimal(12, 4)
  stockAfter   Decimal?    @map("stock_after") @db.Decimal(12, 4)
  vendorId     String?     @map("vendor_id") @db.Uuid
  customerId   String?     @map("customer_id") @db.Uuid
  refJoId      String?     @map("ref_jo_id") @db.Uuid
  refDoId      String?     @map("ref_do_id") @db.Uuid
  refInvoiceId String?     @map("ref_invoice_id") @db.Uuid
  refGrId      String?     @map("ref_gr_id") @db.Uuid
  refCnId      String?     @map("ref_cn_id") @db.Uuid
  parentTxId   String?     @map("parent_tx_id") @db.Uuid
  taxInvoiceNo String?     @map("tax_invoice_no") @db.VarChar(50)
  baseAmount   Decimal?    @map("base_amount") @db.Decimal(14, 2)
  vatAmount    Decimal?    @map("vat_amount") @db.Decimal(14, 2)
  vatType      VatType?    @map("vat_type")
  arAmount     Decimal?    @map("ar_amount") @db.Decimal(14, 2)
  apAmount     Decimal?    @map("ap_amount") @db.Decimal(14, 2)
  apArStatus   ApArStatus? @map("ap_ar_status")
  cogsUnit     Decimal?    @map("cogs_unit") @db.Decimal(12, 2)
  reason       String?     @db.Text
  approvedBy   String?     @map("approved_by") @db.Uuid
  approvedAt   DateTime?   @map("approved_at") @db.Timestamptz
  createdBy    String      @map("created_by") @db.Uuid
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz

  // Relations (cross-schema)
  item      Item?      @relation(fields: [itemId], references: [id])
  warehouse Warehouse? @relation(fields: [warehouseId], references: [id])
  vendor    Vendor?    @relation("TxLogVendor", fields: [vendorId], references: [id])
  customer  Customer?  @relation("TxLogCustomer", fields: [customerId], references: [id])

  // Self-references
  parentTx          TxLog?  @relation("TxLogParent", fields: [parentTxId], references: [id])
  childTxs          TxLog[] @relation("TxLogParent")
  refJo             TxLog?  @relation("TxLogRefJo", fields: [refJoId], references: [id])
  refJoTargets      TxLog[] @relation("TxLogRefJo")
  refDo             TxLog?  @relation("TxLogRefDo", fields: [refDoId], references: [id])
  refDoTargets      TxLog[] @relation("TxLogRefDo")
  refInvoice        TxLog?  @relation("TxLogRefInvoice", fields: [refInvoiceId], references: [id])
  refInvoiceTargets TxLog[] @relation("TxLogRefInvoice")
  refGr             TxLog?  @relation("TxLogRefGr", fields: [refGrId], references: [id])
  refGrTargets      TxLog[] @relation("TxLogRefGr")
  refCn             TxLog?  @relation("TxLogRefCn", fields: [refCnId], references: [id])
  refCnTargets      TxLog[] @relation("TxLogRefCn")

  // Reverse relation for stock_balance.last_tx_id
  stockBalances StockBalance[]

  // Indexes per design
  @@index([txType, period], name: "idx_tx_log_type_period")
  @@index([itemId, warehouseId], name: "idx_tx_log_item_warehouse")
  @@index([txStatus], name: "idx_tx_log_status")
  @@index([customerId], name: "idx_tx_log_customer")
  @@index([vendorId], name: "idx_tx_log_vendor")
  @@index([parentTxId], name: "idx_tx_log_parent")
  @@map("tx_log")
  @@schema("transactions")
}

// ── Stock Balance ────────────────────────────────────────────────────────────

model StockBalance {
  id          String   @id @default(uuid()) @db.Uuid
  itemId      String   @map("item_id") @db.Uuid
  warehouseId String   @map("warehouse_id") @db.Uuid
  qty         Decimal  @default(0) @db.Decimal(12, 4)
  totalValue  Decimal  @default(0) @map("total_value") @db.Decimal(14, 2)
  ma          Decimal  @default(0) @db.Decimal(12, 2)
  isFrozen    Boolean  @default(false) @map("is_frozen")
  lastTxId    String?  @map("last_tx_id") @db.Uuid
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations (cross-schema)
  item      Item      @relation(fields: [itemId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])
  lastTx    TxLog?    @relation(fields: [lastTxId], references: [id])

  // Unique constraint: one balance per item+warehouse pair
  @@unique([itemId, warehouseId], name: "idx_stock_balance_item_wh")
  // Partial index for frozen balances
  @@index([isFrozen], name: "idx_stock_balance_frozen")
  @@map("stock_balance")
  @@schema("transactions")
}
