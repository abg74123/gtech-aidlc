# =============================================================================
# Terraform Variables — Copy to terraform.tfvars and fill in values
# =============================================================================
# cp terraform.tfvars.example terraform.tfvars

aws_region   = "ap-southeast-1"
environment  = "production"
project_name = "autoflow"

# --- Database ---
db_instance_class        = "db.t3.medium"
db_allocated_storage     = 20
db_max_allocated_storage = 100
db_name                  = "autoflow"
db_username              = "autoflow"

# --- ECS / API ---
api_cpu           = 512
api_memory        = 1024
api_desired_count = 2
api_min_count     = 1
api_max_count     = 4

# --- Application Secrets (REQUIRED — do not commit real values) ---
jwt_secret = "CHANGE-ME-use-a-strong-random-secret"

# --- Domain (optional) ---
# domain_name = "autoflow.example.com"
